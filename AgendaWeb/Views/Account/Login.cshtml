@{
    Layout = null;
    ViewData["Title"] = "Tu Agenda Personal - Inicia Sesión";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        :root {
            /* Cargando desde tu carpeta wwwroot/images */
            --bg-wood: url('/images/madera_fondo.jpg');
            --bg-leather: url('/images/cuero_tapa.jpg');
            --bg-paper: url('/images/papel_interior.jpg');
            --ribbon-color: #D4982C; /* Rojo intenso para el separador */
        }

        body, html {
            margin: 0; padding: 0; height: 100%;
            overflow: hidden; font-family: 'Georgia', serif; /* Fuente tipo libro */
            /* FONDO DE MADERA FOTORREALISTA */
            background-image: var(--bg-wood);
            background-size: cover;
            background-position: center;
        }

        /* ESCENARIO 3D */
        .desk-scene {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            perspective: 2000px; 
            position: relative;
        }

        /* LA AGENDA  */
        .agenda-book {
            width: 400px; height: 550px;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 1s cubic-bezier(0.64, 0.57, 0.67, 1.53);
            box-shadow: 15px 15px 40px rgba(0,0,0,0.6);
            border-radius: 5px 20px 20px 5px;
        }

        .agenda-book.open {
            width: 800px;
            transform: rotateX(10deg) rotateY(0deg); /* Pequeña inclinación para verlo mejor */
        }

        /* TAPA DE CUERO */
        .cover-leather {
            position: absolute; width: 100%; height: 100%;
            background-image: var(--bg-leather);
            background-size: cover;
            border-radius: 5px 20px 20px 5px;
            transform-origin: left;
            transition: transform 1.2s ease-in-out;
            backface-visibility: hidden;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            color: #EBD09E; /* Dorado sutil para las letras */
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
            border: 1px solid rgba(0,0,0,0.3);

            z-index: 5; 
        }


        .agenda-book.open .cover-leather {
            transform: rotateY(-170deg);
        }


        .cover-leather .text-center {
            position: relative;
            z-index: 6; 
        }

        .inner-pages {
            position: absolute; width: 100%; height: 100%;
            background-image: var(--bg-paper);
            background-size: cover;
            border-radius: 5px 15px 15px 5px;
            z-index: 1;
            display: flex;
            opacity: 0;
            transition: opacity 0.5s ease;
            box-shadow: inset 5px 0 15px rgba(0,0,0,0.2); 
        }

        .agenda-book.open .inner-pages {
            opacity: 1;
        }

        .page-spine {
            width: 50%; height: 100%;
            border-right: 1px solid rgba(0,0,0,0.1);
            position: relative;
        }


        .page-ribbon {
            position: absolute;
            top: 0; right: 40px;
            width: 15px; height: 100%;
            background-color: var(--ribbon-color);
            z-index: 100;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
            cursor: ns-resize; 
            transition: height 0.3s ease, transform 0.3s ease;
            transform-origin: top;
            border-radius: 0 0 5px 5px;
        }

        .page-ribbon:hover {
            height: 105%;
            background-color: #e74c3c;
        }

        .agenda-book.open .page-ribbon {
            display: none;
        }

        .login-form-container {
            width: 50%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            padding: 50px;
        }

        .login-form {
            width: 100%;
            font-family: 'Courier New', Courier, monospace; 
            color: #2c3e50;
        }

        .login-input {
            background: transparent;
            border: none;
            border-bottom: 2px solid rgba(0,0,0,0.2);
            width: 100%;
            padding: 10px;
            font-size: 1.2rem;
            margin-bottom: 30px;
            color: #34495e;
        }

        .login-input:focus {
            outline: none;
            border-bottom-color: var(--ribbon-color);
        }

        .login-button {
            background-color: var(--ribbon-color);
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 1.3rem;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 3px 3px 10px rgba(0,0,0,0.3);
            width: 100%;
        }

        .login-button:hover {
            background-color: #e74c3c;
            transform: translateY(-2px);
        }
/* Ajuste para que las dos páginas respiren */
.page-spine, .login-form-container {
    width: 50% !important;
    height: 100%;
    padding: 40px !important;
}

.login-input {
    /* Mantén tu estilo, solo asegúrate que el texto sea oscuro */
    color: #2c3e50;
}
    </style>
</head>
<body>

<div class="desk-scene">
    
    <div class="agenda-book @(ViewBag.MantenerAbierta == true ? "open" : "")" id="agendaBook">

        <div class="cover-leather">
            <div class="text-center">
                <i class="bi bi-journal-bookmark fs-1 mb-3"></i>
                <div class="cover-title">AGENDA</div>
                <p class="fs-5 opacity-75 mt-3">Mi Día, Mi Orden</p>
                <div class="mt-5 text-muted small">Arrastra la cinta roja para abrir <i class="bi bi-arrow-down"></i></div>
            </div>
        </div>

        <div class="page-ribbon" id="pageRibbon"></div>

        <div class="inner-pages">
        
    <div class="page-spine d-flex align-items-center justify-content-center p-4">
        <div id="sectionRegister" class="w-100" style="font-family: 'Courier New';">
            <h3 class="text-center fw-bold mb-4">Nueva Cuenta</h3>
            
            @if (ViewBag.ErrorRegister != null) {
                <div class="alert alert-warning py-1 small">@ViewBag.ErrorRegister</div>
            }

            <form asp-action="Register" method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3" style="font-family: 'Courier New';"></div>
                <input name="Nombre" type="text" class="login-input" placeholder="Tu Nombre" required style="font-size: 0.9rem; margin-bottom: 15px;">
                <input name="Email" type="email" class="login-input" placeholder="Tu Correo" required style="font-size: 0.9rem; margin-bottom: 15px;">
            <div class="mb-4">
                <label class="fw-bold small d-block">Contraseña:</label>
                <div style="display: flex !important; align-items: center !important; border-bottom: 2px solid rgba(0,0,0,0.2) !important; width: 100% !important;">
                    
                    <input name="Password" type="password" id="regPassword" 
                        class="login-input" placeholder="Contraseña" required 
                        style="border: none !important; margin-bottom: 0 !important; width: 90% !important; background: transparent !important; padding: 10px 0 !important;">
                    
                    <i class="bi bi-eye text-muted" 
                    style="cursor: pointer !important; font-size: 1.3rem !important; width: 10% !important; text-align: right !important;"
                    onclick="toggleInput('regPassword', this)"></i>
                </div>
            </div>

            <div class="mb-4 p-3">
                <label class="fw-bold small d-block">Confirmar Contraseña:</label>
                <div style="display: flex !important; align-items: center !important; border-bottom: 2px solid rgba(0,0,0,0.2) !important; width: 100% !important;">
                    
                    <input name="ConfirmPassword" type="password" id="regConfirmPassword" 
                        class="login-input" placeholder="Repite Contraseña" required 
                        style="border: none !important; margin-bottom: 0 !important; width: 90% !important; background: transparent !important; padding: 10px 0 !important;">
                    
                    <i class="bi bi-eye text-muted" 
                    style="cursor: pointer !important; font-size: 1.3rem !important; width: 10% !important; text-align: right !important;"
                    onclick="toggleInput('regConfirmPassword', this)"></i>
                </div>
            </div>
                <button type="submit" class="login-button py-2 p-4" style="font-size: 1rem;">
                    REGISTRARME <i class="bi bi-pencil-square ms-2"></i>
                </button>
            </form>
            
        </div>
    </div>
    
    <div class="login-form-container">
        <div id="sectionLogin" class="w-100">
            <form asp-action="Login" method="post" class="login-form">
                <h2 class="text-center mb-4 fw-bold">Iniciar Sesión</h2>
                
                @if (ViewBag.Success != null) {
                    <div class="alert alert-success py-1 small">@ViewBag.Success</div>
                }
                @if (ViewBag.ErrorLogin != null) {
                    <div class="alert alert-danger py-1 small">@ViewBag.ErrorLogin</div>
                }

                <label class="fw-bold small">Correo:</label>
                <input name="Email" type="email" value="@Model?.Email" class="login-input" placeholder="ejemplo@correo.com" required>

                <label class="fw-bold small">Contraseña:</label>
                <input name="Password" type="password" class="login-input" placeholder="••••••••" required>

                <button type="submit" class="login-button">
                    ACCEDER <i class="bi bi-arrow-right-short ms-2"></i>
                </button>
            </form>
        </div>
    </div>
</div>

    </div>

</div>

<script>
 
    function toggleInput(inputId, iconElement) {
        const input = document.getElementById(inputId);
        if (!input) return;

        if (input.type === "password") {
            input.type = "text";
            iconElement.classList.remove('bi-eye');
            iconElement.classList.add('bi-eye-slash'); // Ojo tachado
        } else {
            input.type = "password";
            iconElement.classList.remove('bi-eye-slash');
            iconElement.classList.add('bi-eye'); // Ojo abierto
        }
    }

    const ribbon = document.getElementById('pageRibbon');
    const book = document.getElementById('agendaBook');

    let isDragging = false;
    let startY = 0;
    const dragThreshold = 100; 

    
    ribbon.addEventListener('mousedown', (e) => {
        isDragging = true;
        startY = e.clientY; 
        ribbon.style.transition = 'none'; 
        ribbon.style.backgroundColor = '#e74c3c'; 
        console.log("Agarramos la cinta...");
    });

    // MOVER 
    window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;

        
        const deltaY = e.clientY - startY;

        if (deltaY > 0 && deltaY < 200) {
           
            ribbon.style.transform = `translateY(${deltaY}px)`;
        }
    });

    // SOLTAR
    window.addEventListener('mouseup', (e) => {
        if (!isDragging) return;
        
        isDragging = false;
        const deltaY = e.clientY - startY;
        
        ribbon.style.transition = 'all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275)'; 

        if (deltaY >= dragThreshold) {
  
            console.log("¡Agenda Abierta!");
            book.classList.add('open');
            ribbon.style.opacity = "0"; 
        } else {
            console.log("No jalaste lo suficiente");
            ribbon.style.transform = 'translateY(0px)';
            ribbon.style.backgroundColor = '#c0392b';
        }
    });
    window.addEventListener('keydown', (e) => {
        if (e.key === "Enter") {
            book.classList.add('open');
            ribbon.style.opacity = "0";
        }
    });
</script>

</body>
</html>