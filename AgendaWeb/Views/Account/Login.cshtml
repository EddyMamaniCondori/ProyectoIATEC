@{
    Layout = null;
    ViewData["Title"] = "Tu Agenda Personal - Inicia Sesión";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        :root {
            /* Cargando desde tu carpeta wwwroot/images */
            --bg-wood: url('/images/madera_fondo.jpg');
            --bg-leather: url('/images/cuero_tapa.jpg');
            --bg-paper: url('/images/papel_interior.jpg');
            --ribbon-color: #D4982C; /* Rojo intenso para el separador */
        }

        body, html {
            margin: 0; padding: 0; height: 100%;
            overflow: hidden; font-family: 'Georgia', serif; /* Fuente tipo libro */
            /* FONDO DE MADERA FOTORREALISTA */
            background-image: var(--bg-wood);
            background-size: cover;
            background-position: center;
        }

        /* ESCENARIO 3D */
        .desk-scene {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            perspective: 2000px; /* Crucial para el efecto 3D */
            position: relative;
        }

        /* LA AGENDA (Contenedor Principal) */
        .agenda-book {
            width: 400px; height: 550px;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 1s cubic-bezier(0.64, 0.57, 0.67, 1.53);
            /* Sombra realista proyectada en la madera */
            box-shadow: 15px 15px 40px rgba(0,0,0,0.6);
            border-radius: 5px 20px 20px 5px;
        }

        /* Cuando la agenda está abierta (Estado Final) */
        .agenda-book.open {
            width: 800px;
            transform: rotateX(10deg) rotateY(0deg); /* Pequeña inclinación para verlo mejor */
        }

        /* TAPA DE CUERO (Frente) */
        .cover-leather {
            position: absolute; width: 100%; height: 100%;
            background-image: var(--bg-leather);
            background-size: cover;
            border-radius: 5px 20px 20px 5px;
            transform-origin: left;
            transition: transform 1.2s ease-in-out;
            backface-visibility: hidden;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            color: #EBD09E; /* Dorado sutil para las letras */
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
            border: 1px solid rgba(0,0,0,0.3);

            z-index: 5; /* Antes estaba más alto, bajémoslo */
        }

        /* Efecto de apertura de la tapa */
        .agenda-book.open .cover-leather {
            transform: rotateY(-170deg); /* Se abre hacia la izquierda */
        }

        /* 2. EL TÍTULO Y TEXTOS (Asegurar que estén dentro de la tapa) */
        .cover-leather .text-center {
            position: relative;
            z-index: 6; /* Un poco más que la tapa, pero menos que la cinta */
        }

        /* PÁGINAS INTERIORES (Papel) */
        .inner-pages {
            position: absolute; width: 100%; height: 100%;
            background-image: var(--bg-paper);
            background-size: cover;
            border-radius: 5px 15px 15px 5px;
            z-index: 1;
            display: flex;
            opacity: 0;
            transition: opacity 0.5s ease;
            box-shadow: inset 5px 0 15px rgba(0,0,0,0.2); /* Sombra en el pliegue */
        }

        .agenda-book.open .inner-pages {
            opacity: 1;
        }

        /* Divisor central de las páginas */
        .page-spine {
            width: 50%; height: 100%;
            border-right: 1px solid rgba(0,0,0,0.1);
            position: relative;
        }

        /* EL SEPARADOR DE PÁGINAS (La Cintita Interactiva) */
        .page-ribbon {
            position: absolute;
            top: 0; right: 40px;
            width: 15px; height: 100%;
            background-color: var(--ribbon-color);
            z-index: 100; /* Entre la tapa y las páginas */
            box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
            cursor: ns-resize; /* Cursor de arrastre vertical */
            transition: height 0.3s ease, transform 0.3s ease;
            transform-origin: top;
            border-radius: 0 0 5px 5px;
        }
        
        /* Efecto de "jalón" visual */
        .page-ribbon:hover {
            height: 105%;
            background-color: #e74c3c;
        }

        /* Ocultar la cinta cuando está abierto */
        .agenda-book.open .page-ribbon {
            display: none;
        }

        /* FORMULARIO DE LOGIN (Escrito "a mano" en el papel) */
        .login-form-container {
            width: 50%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            padding: 50px;
        }

        .login-form {
            width: 100%;
            font-family: 'Courier New', Courier, monospace; /* Fuente tipo máquina de escribir */
            color: #2c3e50;
        }

        .login-input {
            background: transparent;
            border: none;
            border-bottom: 2px solid rgba(0,0,0,0.2);
            width: 100%;
            padding: 10px;
            font-size: 1.2rem;
            margin-bottom: 30px;
            color: #34495e;
        }

        .login-input:focus {
            outline: none;
            border-bottom-color: var(--ribbon-color);
        }

        .login-button {
            background-color: var(--ribbon-color);
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 1.3rem;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 3px 3px 10px rgba(0,0,0,0.3);
            width: 100%;
        }

        .login-button:hover {
            background-color: #e74c3c;
            transform: translateY(-2px);
        }

    </style>
</head>
<body>

<div class="desk-scene">
    
    <div class="agenda-book" id="agendaBook">
        
        <div class="cover-leather">
            <div class="text-center">
                <i class="bi bi-journal-bookmark fs-1 mb-3"></i>
                <div class="cover-title">AGENDA</div>
                <p class="fs-5 opacity-75 mt-3">Mi Día, Mi Orden</p>
                <div class="mt-5 text-muted small">Arrastra la cinta roja para abrir <i class="bi bi-arrow-down"></i></div>
            </div>
        </div>

        <div class="page-ribbon" id="pageRibbon"></div>

        <div class="inner-pages">
            <div class="page-spine">
                </div>
            
            <div class="login-form-container">
                <form asp-action="Login" asp-controller="Account" method="post" class="login-form">
                    <h1 class="text-center mb-5 fw-bold" style="font-family: 'Georgia', serif;">Iniciar Sesión</h1>
                    
                    <div class="mb-3">
                        <label class="fw-bold">Correo Electrónico:</label>
                        <input name="Email" type="email"  class="login-input" placeholder="ejemplo@correo.com">
                    </div>

                    <div class="mb-5">
                        <label class="fw-bold">Contraseña:</label>
                        <input name="Password" type="password"  class="login-input" placeholder="••••••••">
                    </div>

                    <button type="submit" class="login-button">
                        ACCEDER <i class="bi bi-arrow-right-short ms-2"></i>
                    </button>
                </form>
            </div>
        </div>

    </div>

</div>

<script>
    const ribbon = document.getElementById('pageRibbon');
    const book = document.getElementById('agendaBook');

    let isDragging = false;
    let startY = 0;
    const dragThreshold = 100; // Bajamos un poco el límite para que sea más fácil

    // 1. INICIAR EL ARRASTRE
    ribbon.addEventListener('mousedown', (e) => {
        isDragging = true;
        startY = e.clientY; // Guarda dónde estaba el mouse al hacer clic
        ribbon.style.transition = 'none'; 
        ribbon.style.backgroundColor = '#e74c3c'; // Cambio de color visual
        console.log("Agarramos la cinta...");
    });

    // 2. MOVER (Mientras el mouse se mueva por TODA la ventana)
    window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;

        // Calculamos cuánto ha bajado el mouse desde el punto inicial
        const deltaY = e.clientY - startY;

        if (deltaY > 0 && deltaY < 200) {
            // Movemos la cinta físicamente siguiendo al mouse
            ribbon.style.transform = `translateY(${deltaY}px)`;
        }
    });

    // 3. SOLTAR
    window.addEventListener('mouseup', (e) => {
        if (!isDragging) return;
        
        isDragging = false;
        const deltaY = e.clientY - startY;
        
        ribbon.style.transition = 'all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275)'; // Efecto rebote

        if (deltaY >= dragThreshold) {
            // ¡ÉXITO! Abrimos la agenda
            console.log("¡Agenda Abierta!");
            book.classList.add('open');
            ribbon.style.opacity = "0"; // Escondemos la cinta al abrir
        } else {
            // FALLO: La cinta regresa a su sitio
            console.log("No jalaste lo suficiente");
            ribbon.style.transform = 'translateY(0px)';
            ribbon.style.backgroundColor = '#c0392b';
        }
    });

    // EXTRA: Permitir abrir también con la tecla ENTER para evaluadores rápidos
    window.addEventListener('keydown', (e) => {
        if (e.key === "Enter") {
            book.classList.add('open');
            ribbon.style.opacity = "0";
        }
    });
</script>

</body>
</html>