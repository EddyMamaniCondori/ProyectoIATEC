@{
    ViewData["Title"] = "Panel de Control";
}

@section Styles {
    <style>
        .card-dashboard {
            border: none;
            border-radius: 15px;
            transition: all 0.3s ease;
        }
        .card-dashboard:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
        .border-live {
            border-left: 5px solid #dc3545 !important; /* Rojo para lo que está pasando ahora */
        }
        .border-upcoming {
            border-left: 5px solid #0dcaf0 !important; /* Cyan para lo próximo */
        }
        .blink {
            animation: pulse-red 2s infinite;
        }
        @@keyframes pulse-red {
            0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); }
            100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
        }
        .empty-state {
            padding: 40px;
            text-align: center;
            background: #f8f9fa;
            border-radius: 10px;
            border: 2px dashed #dee2e6;
        }
    </style>
}

@{
    // 🚩 Lógica para el saludo dinámico según la hora del servidor
    var hora = DateTime.Now.Hour;
    string saludo;

    if (hora >= 6 && hora < 12) { saludo = "¡Buenos días"; }
    else if (hora >= 12 && hora < 19) { saludo = "¡Buenas tardes"; }
    else { saludo = "¡Buenas noches"; }

    var nombreCompleto = User.FindFirst("Nombre")?.Value 
                         ?? User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value 
                         ?? User.Identity?.Name 
                         ?? "Usuario";
}


<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="mb-4">
            <h2 class="fw-bold text-primary mb-0">
                @saludo, <span class="text-dark">@nombreCompleto</span>! 👋
            </h2>
            <p class="text-muted">Aquí tienes el resumen de tu agenda para hoy.</p>
        </div>
        <div id="relojDigital" class="h4 fw-bold text-dark bg-white shadow-sm p-3 rounded-3 border">
            00:00:00
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm h-100 card-dashboard">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-danger">
                        <i class="bi bi-broadcast-pin me-2"></i>En Curso
                    </h5>
                    <span class="badge bg-danger blink">VIVO</span>
                </div>
                <div class="card-body" id="contenedorEnCurso">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm h-100 card-dashboard">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold text-info">
                        <i class="bi bi-calendar-check me-2"></i>Siguientes Eventos
                    </h5>
                </div>
                <div class="card-body" id="contenedorProximos">
                    <div class="text-center py-5">
                        <div class="spinner-border text-info" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
        
        cargarDashboard();
        
        // Refrescar automáticamente cada 5 minutos
        setInterval(cargarDashboard, 300000); 
    });

    function actualizarReloj() {
        const ahora = new Date();
        const reloj = document.getElementById('relojDigital');
        if(reloj) reloj.innerText = ahora.toLocaleTimeString('es-BO');
    }

    async function cargarDashboard() {
        const token = localStorage.getItem('token');
        console.log("🚀 Intentando cargar Dashboard...");

        try {
            const res = await fetch('http://localhost:5188/api/Dashboard/resumen', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            
            if (!res.ok) throw new Error("Error en la petición al servidor");
            const data = await res.json();

            
            renderizarSeccion('contenedorEnCurso', data.enCurso || data.EnCurso, 'live');
            renderizarSeccion('contenedorProximos', data.proximos || data.Proximos, 'upcoming');

        } catch (error) {
            console.error(" Error:", error);
            const msg = '<p class="text-danger text-center">No se pudo conectar con el servidor.</p>';
            document.getElementById('contenedorEnCurso').innerHTML = msg;
            document.getElementById('contenedorProximos').innerHTML = msg;
        }
    }

    function renderizarSeccion(idContenedor, lista, tipo) {
        const contenedor = document.getElementById(idContenedor);
        if(!contenedor) return;

        contenedor.innerHTML = ''; 

        if (!lista || lista.length === 0) {
            contenedor.innerHTML = `
                <div class="empty-state">
                    <i class="bi bi-inbox text-muted display-4"></i>
                    <p class="mt-2 mb-0 text-muted">No hay eventos para mostrar.</p>
                </div>`;
            return;
        }

        let html = '';
        lista.forEach(ev => {
            const borderClass = tipo === 'live' ? 'border-live' : 'border-upcoming';
            const badgeClass = tipo === 'live' ? 'bg-danger' : 'bg-info text-dark';
            
            
            const hInicio = ev.hora_inicio ? ev.hora_inicio.substring(0, 5) : "00:00";
            const hFin = ev.hora_finalizacion ? ev.hora_finalizacion.substring(0, 5) : "00:00";
            
            
            const lugarTexto = ev.lugar ? (ev.lugar.length > 20 ? ev.lugar.substring(0, 20) + "..." : ev.lugar) : "Lugar no definido";

            html += `
                <div class="card mb-3 shadow-sm border-0 ${borderClass}">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0 text-dark">${ev.nombre}</h6>
                            <span class="badge ${badgeClass} small">${ev.tipo}</span>
                        </div>
                        <div class="row small text-muted">
                            <div class="col-7">
                                <i class="bi bi-clock me-1"></i> ${hInicio} - ${hFin}
                            </div>
                            <div class="col-5 text-end text-truncate">
                                <i class="bi bi-geo-alt me-1"></i> ${lugarTexto}
                            </div>
                        </div>
                        <div class="mt-2 d-flex justify-content-end">
                                
                            </div>
                        </div>
                    </div>`;
            });
            contenedor.innerHTML = html;
        }
    </script>
}