<style>

</style>
<div class="modal fade" id="modalNuevoEvento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-geo-alt-fill me-2"></i>Registrar Evento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formEvento" enctype="multipart/form-data">

                    <input type="hidden" id="id_evento" name="id_evento" value="">
                    <div class="row">
                        <div class="col-md-7 border-end">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Título del Evento</label>
                                <input type="text" class="form-control" name="nombre" placeholder="Nombre del evento" required>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small">Fecha Inicio</label>
                                    <input type="date" id="fecha_inicio" class="form-control" name="fecha_inicio" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small">Hora Inicio</label>
                                    <input type="time" id="hora_inicio" class="form-control" name="hora_inicio" required>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">Fecha Fin</label>
                                    <input type="date" id="fecha_finalizacion" class="form-control" name="fecha_finalizacion" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">Hora Fin</label>
                                    <input type="time" id="hora_finalizacion" class="form-control" name="hora_finalizacion" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Descripción</label>
                                <textarea class="form-control" name="descripcion" rows="2"></textarea>
                            </div>
                            

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Invitación (Imagen)</label>
                                    <input type="file" class="form-control" name="imagen_file" accept="image/*">
                                
                                </div>
                                <div class="col-md-6 mb-3">
                                        <div class="d-flex gap-4 bg-white p-2 rounded border">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="radio" name="tipo" id="checkCompartido" value="Compartido" checked>
                                                <label class="form-check-label fw-bold text-primary" for="checkCompartido">
                                                    <i class="fas fa-globe me-1"></i> Compartido
                                                </label>
                                            </div>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="radio" name="tipo" id="checkExclusivo" value="Exclusivo">
                                                <label class="form-check-label fw-bold text-danger" for="checkExclusivo">
                                                    <i class="fas fa-lock me-1"></i> Exclusivo
                                                </label>
                                            </div>
                                        </div>
                                        <small id="tipoTexto" class="text-muted mt-1 d-block">Podrás tener varios eventos en este mismo horario.</small>
                                </div>
                                
                            </div>
                            
                        </div>

                        <div class="col-md-5 bg-light p-3">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Buscar Lugar / Dirección</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white"><i class="bi bi-search text-primary"></i></span>
                                    <input type="text" id="direccion" class="form-control" name="lugar" placeholder="Escribe una calle, plaza o local...">
                                </div>
                            </div>
                            
                            <div id="mapa" style="height: 300px; border: 1px solid #ddd; border-radius: 5px;"></div>
                            
                            <input type="hidden" name="latitud" id="lat">
                            <input type="hidden" name="longitud" id="lng">
                            
                            <p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i> Puedes arrastrar el marcador en el mapa para ajustar la ubicación exacta.</p>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="submit" form="formEvento" class="btn btn-primary px-4">Guardar Evento</button>
            </div>
        </div>
    </div>
</div>